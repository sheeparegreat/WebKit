#if PLATFORM(COCOA)

[WebKitSecureCodingClass=NSURLRequest.class] webkit_secure_coding NSURLRequest {
# protocolProperties: Dictionary of plist types
    protocolProperties: Dictionary
    isMutable: CFBooleanRef
    URL: URL
    timeout: Number
    cachePolicy: Number
    mainDocumentURL: URL?
    shouldHandleHTTPCookies: CFBooleanRef
    explicitFlags: NSNumber
    allowCellular: CFBooleanRef
    preventsIdleSystemSleep: CFBooleanRef
    timeWindowDelay: Number
    timeWindowDuration: Number
    networkServiceType: Number
    requestPriority: Number
    isHTTP: CFBooleanRef?
    httpMethod: String?
# headerFields Dictionary? of <String, Array<String>> or <String, String>
    headerFields: Dictionary?
    body: NSData?
# bodyParts Array? of <Data> or <String>
    bodyParts: NSArray?

    startTimeoutTime: Number?
    requiresShortConnectionTimeout: CFBooleanRef?
    preventHSTSStorage: CFBooleanRef?
    ignoreHSTS: CFBooleanRef?
    schemeWasUpgradedDueToDynamicHSTS: CFBooleanRef?
    payloadTransmissionTimeout: Number?
    allowedProtocolTypes: Number?
    boundInterfaceIdentifier: String?
    allowsExpensiveNetworkAccess: CFBooleanRef?
    allowsConstrainedNetworkAccess: CFBooleanRef?
    allowsUCA: CFBooleanRef?
    assumesHTTP3Capable: CFBooleanRef?
    attribution: Number?
    knownTracker: CFBooleanRef?
    trackerContext: String?
    privacyProxyFailClosed: CFBooleanRef?
    privacyProxyFailClosedForUnreachableNonMainHosts: CFBooleanRef?
    privacyProxyFailClosedForUnreachableHosts: CFBooleanRef?
    requiresDNSSECValidation: CFBooleanRef?
    allowsPersistentDNS: CFBooleanRef?
    prohibitPrivacyProxy: CFBooleanRef?
    allowPrivateAccessTokensForThirdParty: CFBooleanRef?
    useEnhancedPrivacyMode: CFBooleanRef?
    blockTrackers: CFBooleanRef?
    failInsecureLoadWithHTTPSDNSRecord: CFBooleanRef?
    isWebSearchContent: CFBooleanRef?
# contentDispositionEncodingFallbackArray: Array<Number>
    contentDispositionEncodingFallbackArray: Array?
}

#endif // PLATFORM(COCOA)
